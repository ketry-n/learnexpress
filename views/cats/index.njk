{% extends 'partials/layout.njk' %}
{% block title %}Cats{% endblock %}
{% block content %}
<h1>Cats</h1>
<a class="btn btn-primary" href="/cats/create">Add cat</a>

<nav class="mt-2" aria-label="Page navigation example">
  <ul class="pagination">
    <li class="page-item"><a class="page-link" href="#">Previous</a></li>
    {% for page in range(1,pages+1) %}
        {% if page == currentPage %}
        {% else %}
             <li class="page-item active"><a class="page-link" href="/cats?page={{page}}">{{page}}</a></li> 
        {% endif %}
    {% endfor %}
    <li class="page-item"><a class="page-link" href="#">Next</a></li>
  </ul>
</nav>

<table class="table table-striped table-hover">
    <thead>
        <th>ID</th>
        <th>Name</th>
        <th>Birth Year</th>
        <th>Action</th>
    </thead>
    <tbody>
        {% for cat in cats %}
        <tr>
            <td>{{ cat.id }}</td>
            <td>{{ cat.name }}</td>
            <td>{{ cat.birthyear }}</td>
            <td>
                <div class="btn-group">
                    <a href="/cats/view?id={{ cat.id }}" class="btn btn-info">View</a>
                    <a href="/cats/edit?id={{ cat.id }}" class="btn btn-warning">Edit</a>
                    <a href="/cats/delete?id={{ cat.id }}" class="btn btn-danger">Delete</a>
                </div>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}